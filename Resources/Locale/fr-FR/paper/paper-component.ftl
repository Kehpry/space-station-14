### UI

paper-ui-blank-page-message = Cette page a été intentionnellement laissée vide.

# Affiché lorsque du texte est écrit sur le papier examiné
paper-component-examine-detail-has-words = {CAPITALIZE(THE($paper))} a quelque chose d'écrit dessus.
# Affiché lorsque le papier examiné porte un tampon
paper-component-examine-detail-stamped-by = {CAPITALIZE(THE($paper))} {CONJUGATE-HAVE($paper)} été tamponné par : {$stamps}.

paper-component-action-stamp-paper-other = {CAPITALIZE(THE($user))} tamponne {THE($target)} avec {THE($stamp)}.
paper-component-action-stamp-paper-self = Vous tamponnez {THE($target)} avec {THE($stamp)}.

# Indicateur pour montrer à quel point un papier est rempli
paper-ui-fill-level = {$currentLength}/{$maxLength}

paper-ui-save-button = Sauvegarder ({$keybind})

paper-tamper-proof-modified-message = Cette page a été écrite avec de l'encre infalsifiable.
