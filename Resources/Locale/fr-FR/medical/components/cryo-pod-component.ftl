# Étiquette du verbe d'éjection.
cryo-pod-verb-noun-occupant = Patient
# Texte d'examen montrant s'il y a un bécher dans le pod et s'il est vide.
cryo-pod-examine = Il y a {INDEFINITE($beaker)} {$beaker} ici.
cryo-pod-empty-beaker = Il est vide !
# Affiché lorsqu'une éjection normale est tentée sur un pod verrouillé.
cryo-pod-locked = Le mécanisme d'éjection est inactif !
