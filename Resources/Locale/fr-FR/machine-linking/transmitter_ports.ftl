signal-port-name-pressed = Pressé
signal-port-description-pressed = Ce port est invoqué chaque fois que l'émetteur est activé.

signal-port-name-on-transmitter = Allumé
signal-port-description-on-transmitter = Ce port est invoqué chaque fois que l'émetteur est allumé.

signal-port-name-off-transmitter = Éteint
signal-port-description-off-transmitter = Ce port est invoqué chaque fois que l'émetteur est éteint.

signal-port-name-status-transmitter = État
signal-port-description-status-transmitter = Ce port est invoqué avec HIGH ou LOW selon l'état de l'émetteur.

signal-port-name-left = Gauche
signal-port-description-left = Ce port est invoqué lorsque le levier est déplacé à l'extrême gauche.

signal-port-name-right = Droite
signal-port-description-right = Ce port est invoqué lorsque le levier est déplacé à l'extrême droite.

signal-port-name-doorstatus = État de la porte
signal-port-description-doorstatus = Ce port est invoqué avec HIGH lorsque la porte s'ouvre et LOW lorsqu'elle termine de se fermer.

signal-port-name-dockstatus = État du quai
signal-port-description-dockstatus = Ce port est invoqué avec HIGH lorsque l'appareil est amarré et LOW lorsqu'il est désamarré.

signal-port-name-middle = Milieu
signal-port-description-middle = Ce port est invoqué lorsque le levier est déplacé en position neutre.

signal-port-name-timer-trigger = Déclenchement du minuteur
signal-port-description-timer-trigger = Ce port est invoqué lorsque le minuteur se déclenche.

signal-port-name-timer-start = Démarrage du minuteur
signal-port-description-timer-start = Ce port est invoqué lorsque le minuteur démarre.

signal-port-name-logic-output = Sortie
signal-port-description-logic-output = Ce port est invoqué avec HIGH ou LOW selon la porte logique sélectionnée et les entrées.

signal-port-name-logic-output-high = Sortie haute
signal-port-description-logic-output-high = Ce port est invoqué lorsque l'entrée a un front montant.

signal-port-name-logic-output-low = Sortie basse
signal-port-description-logic-output-low = Ce port est invoqué lorsque l'entrée a un front descendant.

signal-port-name-air-danger = Danger
signal-port-description-air-danger = Ce port est invoqué avec HIGH en mode danger et LOW sinon.

signal-port-name-air-warning = Avertissement
signal-port-description-air-warning = Ce port est invoqué avec HIGH en mode avertissement et LOW sinon.

signal-port-name-air-normal = Normal
signal-port-description-air-normal = Ce port est invoqué avec HIGH en mode normal et LOW sinon.

signal-port-name-decaying = Détérioration
signal-port-description-decaying = Ce port est invoqué lorsqu'une anomalie liée commence à se détériorer.

signal-port-name-stabilize = Stabilisation
signal-port-description-stabilize = Ce port est invoqué lorsqu'une anomalie liée est normalisée.

signal-port-name-growing = Croissance
signal-port-description-growing = Ce port est invoqué lorsqu'une anomalie liée commence à croître.

signal-port-name-pulse = Pulsation
signal-port-description-pulse = Ce port est invoqué lorsqu'une anomalie liée entre en pulsation.

signal-port-name-supercrit = Supercritique
signal-port-description-supercrit = Ce port est invoqué lorsqu'une anomalie liée explose après avoir atteint l'état supercritique.

signal-port-name-power-charging = Chargement
signal-port-description-power-charging = Ce port est invoqué avec HIGH lorsque la batterie se charge et LOW sinon.

signal-port-name-power-discharging = Déchargement
signal-port-description-power-discharging = Ce port est invoqué avec HIGH lorsque la batterie se décharge et LOW sinon.
