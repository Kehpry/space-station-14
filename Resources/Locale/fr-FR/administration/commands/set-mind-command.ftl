set-mind-command-description = Transfère un esprit à l'entité spécifiée. L'entité doit avoir un {$requiredComponent}. Par défaut, cela forcera les esprits actuellement visitant d'autres entités à revenir (c'est-à-dire, ramener un fantôme à son corps principal).
set-mind-command-help-text = Utilisation : {$command} <entityUid> <nom d'utilisateur> [unvisit]
set-mind-command-target-has-no-content-data-message = Le joueur cible n'a pas de données de contenu (qu'est-ce que c'est ?)
set-mind-command-target-has-no-mind-message = L'entité cible n'a pas d'esprit (avez-vous oublié de la rendre sentiente ?)
