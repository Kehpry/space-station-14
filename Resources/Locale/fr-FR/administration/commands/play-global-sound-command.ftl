play-global-sound-command-description = Joue un son global pour un joueur spécifique ou pour tous les joueurs connectés si aucun joueur n'est spécifié.
play-global-sound-command-help = playglobalsound <chemin> [volume] [utilisateur 1] ... [utilisateur n]
play-global-sound-command-player-not-found = Joueur "{$username}" non trouvé.
