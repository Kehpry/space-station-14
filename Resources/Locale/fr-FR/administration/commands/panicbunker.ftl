cmd-panicbunker-desc = Active ou désactive le bunker de panique, ce qui applique des restrictions plus strictes sur qui peut rejoindre le serveur.
cmd-panicbunker-help = Utilisation : panicbunker
panicbunker-command-enabled = Le bunker de panique a été activé.
panicbunker-command-disabled = Le bunker de panique a été désactivé.

cmd-panicbunker_disable_with_admins-desc = Active ou désactive la fonctionnalité qui désactive le bunker de panique lorsque un administrateur se connecte.
cmd-panicbunker_disable_with_admins-help = Utilisation : panicbunker_disable_with_admins
panicbunker-command-disable-with-admins-enabled = Le bunker de panique sera automatiquement désactivé lorsque des administrateurs seront en ligne.
panicbunker-command-disable-with-admins-disabled = Le bunker de panique ne sera pas automatiquement désactivé lorsque des administrateurs seront en ligne.

cmd-panicbunker_enable_without_admins-desc = Active ou désactive la fonctionnalité qui active le bunker de panique lorsque le dernier administrateur se déconnecte.
cmd-panicbunker_enable_without_admins-help = Utilisation : panicbunker_enable_without_admins
panicbunker-command-enable-without-admins-enabled = Le bunker de panique sera automatiquement activé en l'absence d'administrateurs en ligne.
panicbunker-command-enable-without-admins-disabled = Le bunker de panique ne sera pas automatiquement activé en l'absence d'administrateurs en ligne.

cmd-panicbunker_count_deadminned_admins-desc = Active ou désactive le comptage des administrateurs dégradés lorsqu'on active et désactive automatiquement le bunker de panique.
cmd-panicbunker_count_deadminned_admins-help = Utilisation : panicbunker_count_deadminned_admins
panicbunker-command-count-deadminned-admins-enabled = Le bunker de panique comptera les administrateurs dégradés lorsqu'il sera activé et désactivé automatiquement.
panicbunker-command-count-deadminned-admins-disabled = Le bunker de panique ne comptera pas les administrateurs dégradés lorsqu'il sera activé et désactivé automatiquement.

cmd-panicbunker_show_reason-desc = Active ou désactive l'affichage de la raison pour laquelle le bunker de panique empêche les clients de se connecter.
cmd-panicbunker_show_reason-help = Utilisation : panicbunker_show_reason
panicbunker-command-show-reason-enabled = Le bunker de panique affichera désormais une raison aux utilisateurs qu'il bloque de se connecter.
panicbunker-command-show-reason-disabled = Le bunker de panique ne montrera plus de raison aux utilisateurs qu'il bloque de se connecter.

cmd-panicbunker_min_account_age-desc = Définit ou obtient l'âge minimum du compte en minutes qu'un compte doit avoir pour pouvoir se connecter lorsque le bunker de panique est activé.
cmd-panicbunker_min_account_age-help = Utilisation : panicbunker_min_account_age <minutes>
panicbunker-command-min-account-age-is = L'âge minimum du compte pour le bunker de panique est de {$minutes} minutes.
panicbunker-command-min-account-age-set = L'âge minimum du compte pour le bunker de panique est maintenant de {$minutes} minutes.

cmd-panicbunker_min_overall_minutes-desc = Définit ou obtient le temps de jeu total minimum en minutes qu'un compte doit avoir pour pouvoir se connecter lorsque le bunker de panique est activé.
cmd-panicbunker_min_overall_minutes-help = Utilisation : panicbunker_min_overall_minutes <minutes>
panicbunker-command-min-overall-minutes-is = Le temps de jeu total minimum pour le bunker de panique est de {$minutes} minutes.
panicbunker-command-min-overall-minutes-set = Le temps de jeu total minimum pour le bunker de panique est maintenant de {$minutes} minutes.
