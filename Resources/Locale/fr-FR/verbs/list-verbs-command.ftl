list-verbs-command-description = Liste tous les verbes qu'un joueur peut utiliser sur une entité donnée.
list-verbs-command-help = listverbs <playerUid | "self"> <targetUid>

list-verbs-command-invalid-args = listverbs nécessite 2 arguments.

list-verbs-command-invalid-player-uid = Le uid du joueur n'a pas pu être analysé, ou "self" n'a pas été passé.
list-verbs-command-invalid-target-uid = Le uid de la cible n'a pas pu être analysé.

list-verbs-command-invalid-player-entity = Le uid du joueur donné ne correspond à aucune entité valide.
list-verbs-command-invalid-target-entity = Le uid de la cible donné ne correspond à aucune entité valide.

list-verbs-verb-listing = { $type } : { $verb }
