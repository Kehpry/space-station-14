invoke-verb-command-description = Invoque un verbe avec le nom donné sur une entité, avec l'entité du joueur
invoke-verb-command-help = invokeverb <playerUid | "self"> <targetUid> <verbName | "interaction" | "activation" | "alternative">

invoke-verb-command-invalid-args = invokeverb nécessite 2 arguments.

invoke-verb-command-invalid-player-uid = Le uid du joueur n'a pas pu être analysé, ou "self" n'a pas été passé.
invoke-verb-command-invalid-target-uid = Le uid de la cible n'a pas pu être analysé.

invoke-verb-command-invalid-player-entity = Le uid du joueur donné ne correspond à aucune entité valide.
invoke-verb-command-invalid-target-entity = Le uid de la cible donné ne correspond à aucune entité valide.

invoke-verb-command-success = Verbe '{ $verb }' invoqué sur { $target } avec { $player } comme utilisateur.

invoke-verb-command-verb-not-found = Impossible de trouver le verbe { $verb } sur { $target }.
