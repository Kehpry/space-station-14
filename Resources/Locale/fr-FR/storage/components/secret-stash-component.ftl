comp-secret-stash-verb-take-out-item = Récupérer un objet
comp-secret-stash-verb-take-out-message-something = Sortir le contenu du/de la {$stashname}.
comp-secret-stash-verb-take-out-message-nothing = Il n'y a rien à l'intérieur du/de la {$stashname}.

comp-secret-stash-verb-close = Fermer
