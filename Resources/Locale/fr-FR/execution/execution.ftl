execution-verb-name = Exécuter
execution-verb-message = Utilisez votre arme pour exécuter quelqu'un.

# All the below localisation strings have access to the following variables
# attaquant (la personne commettant l'exécution)
# victime (la personne exécutée)
# arme (l'arme utilisée pour l'exécution)

execution-popup-melee-initial-internal = Vous préparez {THE($weapon)} contre la gorge de {THE($victim)}.
execution-popup-melee-initial-external = { CAPITALIZE(THE($attacker)) } prépare {POSS-ADJ($attacker)} {$weapon} contre la gorge de {THE($victim)}.
execution-popup-melee-complete-internal = Vous tranchez la gorge de {THE($victim)} !
execution-popup-melee-complete-external = { CAPITALIZE(THE($attacker)) } tranche la gorge de {THE($victim)} !

execution-popup-self-initial-internal = Vous préparez {THE($weapon)} contre votre propre gorge.
execution-popup-self-initial-external = { CAPITALIZE(THE($attacker)) } prépare {POSS-ADJ($attacker)} {$weapon} contre sa propre gorge.
execution-popup-self-complete-internal = Vous vous tranchez la gorge !
execution-popup-self-complete-external = { CAPITALIZE(THE($attacker)) } se tranche la gorge !
