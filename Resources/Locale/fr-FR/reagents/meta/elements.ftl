reagent-name-aluminium = aluminium
reagent-desc-aluminium = Un métal argenté, doux, non magnétique et ductile.

reagent-name-ash = cendre
reagent-desc-ash = Un résidu poudreux gris clair.

reagent-name-carbon = carbone
reagent-desc-carbon = Un solide cristallin noir.

reagent-name-charcoal = charbon de bois
reagent-desc-charcoal = Un solide noir et poreux.

reagent-name-chlorine = chlore
reagent-desc-chlorine = Un gaz jaune-vert toxique pour les humains.

reagent-name-copper = cuivre
reagent-desc-copper = Un métal doux, malléable et ductile, avec une conductivité thermique et électrique très élevée.

reagent-name-fluorine = fluor
reagent-desc-fluorine = Un gaz jaune pâle hautement toxique et extrêmement réactif.

reagent-name-gold = or
reagent-desc-gold = L'or est un métal dense, doux, brillant et le métal le plus malléable et ductile connu.

reagent-name-hydrogen = hydrogène
reagent-desc-hydrogen = Un gaz léger et inflammable.

reagent-name-iodine = iode
reagent-desc-iodine = Couramment ajouté au sel de table comme nutriment. Seul, son goût est bien moins agréable.

reagent-name-iron = fer
reagent-desc-iron = Un métal gris argenté qui forme des oxydes de fer (rouille) au contact de l'air. Souvent allié à d'autres éléments pour créer des alliages comme l'acier.

reagent-name-lithium = lithium
reagent-desc-lithium = Un métal alcalin doux et blanc argenté. Très réactif, il s'enflamme au contact de l'eau.

reagent-name-mercury = mercure
reagent-desc-mercury = Un métal argenté qui est liquide à température ambiante. Il est hautement toxique pour les humains.

reagent-name-potassium = potassium
reagent-desc-potassium = Un métal doux et brillant gris. Encore plus réactif que le lithium.

reagent-name-phosphorus = phosphore
reagent-desc-phosphorus = Un métal réactif utilisé dans les pyrotechniques et les armes.

reagent-name-radium = radium
reagent-desc-radium = Un métal radioactif, blanc argenté à l'état pur. Il brille en raison de sa radioactivité et est hautement toxique.

reagent-name-silicon = silicium
reagent-desc-silicon = Un solide cristallin dur et cassant de couleur bleu-gris.

reagent-name-silver = argent
reagent-desc-silver = Un métal blanc doux et brillant, avec la plus haute conductivité électrique de tous les éléments et la plus haute conductivité thermique de tous les métaux.

reagent-name-sulfur = soufre
reagent-desc-sulfur = Un solide cristallin jaune.

reagent-name-sodium = sodium
reagent-desc-sodium = Un métal alcalin blanc argenté. Hautement réactif à l'état pur.

reagent-name-uranium = uranium
reagent-desc-uranium = Un élément chimique métallique gris de la série des actinides, légèrement radioactif.

reagent-name-zinc = zinc
reagent-desc-zinc = Un métal gris argenté et cassant, souvent utilisé dans les batteries pour transporter la charge.
