### UI

# Verb name for climbing
comp-climbable-verb-climb = Escalader

### Interaction Messages

# Shown to you when your character climbs on $climbable
comp-climbable-user-climbs = Vous sautez sur { THE($climbable) } !

# Shown to others when $user climbs on $climbable
comp-climbable-user-climbs-other  = { CAPITALIZE(THE($user)) } saute sur { THE($climbable) } !

# Shown to you when your character forces someone to climb on $climbable
comp-climbable-user-climbs-force = Vous forcez { THE($moved-user) } à monter sur { THE($climbable) } !

# Shown to others when someone forces other $moved-user to climb on $climbable
comp-climbable-user-climbs-force-other = { CAPITALIZE(THE($user)) } force { THE($moved-user) } à monter sur { THE($climbable) } !

# Shown to you when your character is far away from climbable
comp-climbable-cant-reach = Vous ne pouvez pas atteindre cet endroit !

# Shown to you when your character can't interact with climbable for some reason
comp-climbable-cant-interact = Vous ne pouvez pas faire ça !

# Shown to you when your character isn't able to climb by their own actions
comp-climbable-cant-climb = Vous êtes incapable d'escalader !

# Shown to you when your character tries to force someone else who can't climb onto a climbable
comp-climbable-target-cant-climb = { CAPITALIZE(THE($moved-user)) } ne peut pas aller là-bas !
