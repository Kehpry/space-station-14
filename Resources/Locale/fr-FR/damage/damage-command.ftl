## Damage command loc.

damage-command-description = Ajouter ou retirer des dégâts à une entité.
damage-command-help = Utilisation : {$command} <type/groupe> <quantité> [ignorerRésistances] [uid]

damage-command-arg-type = <type ou groupe de dégâts>
damage-command-arg-quantity = [quantité]
damage-command-arg-target = [cible euid]

damage-command-error-type = {$arg} n'est pas un groupe ou un type de dégâts valide.
damage-command-error-euid = {$arg} n'est pas un uid d'entité valide.
damage-command-error-quantity = {$arg} n'est pas une quantité valide.
damage-command-error-bool = {$arg} n'est pas un booléen valide.
damage-command-error-player = Aucune entité attachée à la session. Vous devez spécifier un uid de cible.
damage-command-error-args = Nombre d'arguments invalide.
