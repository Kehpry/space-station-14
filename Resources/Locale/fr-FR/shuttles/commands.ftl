cmd-ftldisk-desc = Crée un disque de coordonnées FTL pour naviguer vers la carte sur laquelle se trouve l'EntityID donné
cmd-ftldisk-help = ftldisk [EntityID]

cmd-ftldisk-no-transform = L'entité {$destination} n'a pas de composant de transformation !
cmd-ftldisk-no-map = L'entité {$destination} n'a pas de carte !
cmd-ftldisk-no-map-comp = L'entité {$destination} se trouve sur la carte {$map} mais n'a pas de composant de carte.
cmd-ftldisk-map-not-init = L'entité {$destination} est sur la carte {$map} qui n'est pas initialisée ! Vérifiez s'il est sûr d'initialiser, puis initialisez la carte d'abord, sinon les joueurs resteront coincés sur place !
cmd-ftldisk-map-paused = L'entité {$destination} est sur la carte {$map} qui est en pause ! Veuillez d'abord désactiver la pause de la carte, sinon les joueurs resteront coincés sur place.
cmd-ftldisk-planet = L'entité {$destination} se trouve sur la carte du planéte {$map} et nécessitera un point FTL. Il peut déjà exister.
cmd-ftldisk-already-dest-not-enabled = L'entité {$destination} est sur la carte {$map} qui possède déjà un FTLDestinationComponent, mais il n'est pas activé ! Réactivez-le manuellement pour plus de sécurité.
cmd-ftldisk-requires-ftl-point = L'entité {$destination} est sur la carte {$map} qui nécessite un point FTL pour y voyager ! Il peut déjà exister.

cmd-ftldisk-hint = ID réseau de la carte
