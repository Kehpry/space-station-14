# Commandes
## Délai avant la fin du round
emergency-shuttle-command-round-desc = Arrête le chronomètre qui termine le round lorsque la navette d'urgence sort de l'hyperespace.
emergency-shuttle-command-round-yes = Round retardé.
emergency-shuttle-command-round-no = Impossible de retarder la fin du round.

## Amarrer la navette d'urgence
emergency-shuttle-command-dock-desc = Appelle la navette d'urgence et l'amarre à la station... si cela est possible.

## Lancer la navette d'urgence
emergency-shuttle-command-launch-desc = Lance la navette d'urgence plus tôt si possible.

# Navette d'urgence
emergency-shuttle-left = La navette d'urgence a quitté la station. Estimation de {$transitTime} secondes avant que la navette arrive à CentComm.
emergency-shuttle-launch-time = La navette d'urgence décollera dans {$consoleAccumulator} secondes.
emergency-shuttle-docked = La navette d'urgence a accosté {$direction} de la station, {$location}. Elle partira dans {$time} secondes.{$extended}
emergency-shuttle-good-luck = La navette d'urgence n'a pas trouvé de station. Bonne chance.
emergency-shuttle-nearby = La navette d'urgence n'a pas trouvé de port d'amarrage valide. Elle a fait une transition en hyperespace {$direction} de la station, {$location}. Elle partira dans {$time} secondes.{$extended}
emergency-shuttle-extended = {" "}Le temps de lancement a été prolongé en raison de circonstances imprévues.

# Pop-up / annonce du terminal de la navette d'urgence
emergency-shuttle-console-no-early-launches = Le lancement anticipé est désactivé.
emergency-shuttle-console-auth-left = {$remaining} autorisations nécessaires avant le lancement anticipé de la navette.
emergency-shuttle-console-auth-revoked = Autorisation de lancement anticipé révoquée, {$remaining} autorisations nécessaires.
emergency-shuttle-console-denied = Accès refusé.

# Interface utilisateur
emergency-shuttle-console-window-title = Console de la navette d'urgence
emergency-shuttle-ui-engines = MOTEURS :
emergency-shuttle-ui-idle = Inactif
emergency-shuttle-ui-repeal-all = Révoquer tout
emergency-shuttle-ui-early-authorize = Autorisation de lancement anticipé
emergency-shuttle-ui-authorize = AUTORISER
emergency-shuttle-ui-repeal = RÉVOQUER
emergency-shuttle-ui-authorizations = Autorisations
emergency-shuttle-ui-remaining = Restant : {$remaining}

# Divers de la carte
map-name-centcomm = Commandement Central
map-name-terminal = Terminal des arrivées
